# Second Brain Backend - Environment Variables Template
# Copy this file to .env and fill in your values

# Groq API (Get from https://console.groq.com)
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL_NAME=llama-3.1-8b-instant

# Clerk Authentication (Optional - for protected APIs)
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# CORS Origins (comma-separated, include your frontend URL)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Environment (development, staging, production)
ENVIRONMENT=development

# Database paths (for production, use absolute paths or external DB)
VECTOR_DB_PATH=./data/vector_store
SQLITE_DB_PATH=./data/episodic.db

# Embedding model
MODEL_NAME=all-MiniLM-L6-v2
